<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/main_activity_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"/>

        <!-- Elements Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tvElements"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/elements_section_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <ListView
                    android:id="@+id/lvElements"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:dividerHeight="1dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Compounds Section Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/tvCompounds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/compounds_section_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <ListView
                    android:id="@+id/lvCompounds"
                    android:layout_width="match_parent"
                    android:layout_height="120dp" 
                    android:dividerHeight="1dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Selected Compound Display Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <TextView
                android:id="@+id/tvSelectedCompound"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/selected_compound_placeholder"
                android:textSize="16sp"
                android:padding="12dp"
                android:background="@color/textview_display_bg"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- User Selected Elements Display Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <TextView
                android:id="@+id/tvUserSelectedElements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/user_elements_placeholder"
                android:textSize="16sp"
                android:padding="12dp"
                android:background="@color/textview_display_bg"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Ready Button -->
        <Button
            android:id="@+id/btnReady"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_ready_text"
            android:layout_gravity="center_horizontal"/>

    </LinearLayout>
</ScrollView>